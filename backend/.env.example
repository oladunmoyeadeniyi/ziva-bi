# Database — local dev uses plain postgresql://, Render injects its own URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ziva_dev

# JWT — generate a strong random string for production (openssl rand -hex 32)
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# Cloudflare R2 (reserved for future use)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Supabase Storage (M6 — document attachments)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=documents

# App
DEBUG=false

# Platform owner (M9.3b) — UUID of the Ziva BI platform owner account.
# When set, this user's impersonation sessions on live tenants have unrestricted
# access (no sensitive field masking). If unset, all super admins are restricted.
OWNER_USER_ID=
